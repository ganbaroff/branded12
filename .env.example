# Backend (Worker) – set via wrangler secret or Cloudflare Dashboard
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel: password-based login (no Google/Mocha)
# ADMIN_PASSWORD=your-admin-password
# Optional: for signed session cookie (default uses password-derived token)
# ADMIN_SESSION_SECRET=optional-random-secret

# Optional: Gemini API for POST /api/chat (server-side only; do not expose key on client)
# GEMINI_API_KEY=your-google-ai-api-key

# Local dev: create .dev.vars with the same keys for Workers (including ADMIN_PASSWORD)
# See docs/SUPABASE_SETUP.md

# Frontend (optional) – Vite env; prefix with VITE_
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_FB_PIXEL_ID=XXXXXXXXXX
# VITE_YM_ID=XXXXXXXX
